{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ArrDeck",
  "version": "0.3.9",
  "identifier": "com.arrdeck.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "ArrDeck",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "RWS696DW8s0de5Eqaifu8EYj3tG4BK6ycr6vwnO64+V6XzVgMpER4n9t",
      "endpoints": [
        "https://github.com/CJKaufman/ArrDeck/releases/latest/download/latest.json"
      ],
      "installMode": "passive"
    }
  }
}

