# Auto detect text files and perform LF normalization
* text=auto eol=lf

# Force LF for source files
*.ts text eol=lf
*.tsx text eol=lf
*.css text eol=lf
*.json text eol=lf
*.md text eol=lf
*.html text eol=lf
*.toml text eol=lf
*.rs text eol=lf
*.yml text eol=lf

# Force binary for compiled/binary files
*.png binary
*.ico binary
*.icns binary
*.exe binary
*.msi binary
